rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Allow read/write for all collections so that Node.js client-initialized server can function)
    match /{document=**} {
      allow read, write: if true;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Customers Rules
    match /customers/{customerId} {
      allow read, write: if true;
    }

    // 2. Orders Rules
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // 3. Campaigns Rules
    match /campaigns/{campaignId} {
      allow read, write: if true;
    }

    // 4. Communications Rules
    match /communications/{communicationId} {
      allow read, write: if true;
    }

    // 5. Campaign Stats Rules
    match /campaign_stats/{campaignId} {
      allow read, write: if true;
    }

    // 6. Chat Messages Rules
    match /chat_messages/{messageId} {
      allow read, write: if true;
    }
  }
}
